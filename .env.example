# ── AI Provider Keys ─────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key        # optional if not using OpenAI
CLAUDE_API_KEY=your_claude_api_key

# ── Email Verification ────────────────────────────────────────────────────────
REOON_API_KEY=your_reoon_api_key

# ── Local DB Server (ngrok) ───────────────────────────────────────────────────
# In development: http://localhost:4000
# In production (Vercel): paste your ngrok https:// URL here
LOCAL_DB_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app

# Shared secret between Vercel and your local server
# Set the SAME value in both here and in local-server/.env
LOCAL_DB_SECRET=replace-with-a-long-random-string
